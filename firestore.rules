rules_version='2'

service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      // This rule allows anyone with your database reference to view, edit,
      // and delete all data in your database. It is useful for getting
      // started, but it is configured to expire after 30 days because it
      // leaves your app open to attackers. At that time, all client
      // requests to your database will be denied.
      //
      // Make sure to write security rules for your app before that time, or
      // else all client requests to your database will be denied until you
      // update your rules.
      allow read, write: if request.time < timestamp.date(2026, 4, 6);
    }

    // ── Referral leads (public form + payment info page) ──
    // These rules will take effect when the blanket rule above expires.
    match /referral_leads/{referralId} {
      // Anyone can create a new referral (public form)
      allow create: if true;
      // Anyone with the doc ID can read (payment info page)
      allow read: if true;
      // Payment info page can update only payment fields
      allow update: if request.resource.data.diff(resource.data).affectedKeys()
        .hasOnly(['paymentInfo', 'paymentInfoUpdatedAt']);
    }

    // ── NFC Sites (public read for location info, admin write) ──
    match /nfc_sites/{locationId} {
      // Public can read location name + vendor name (needed for clock-in page)
      // Note: siteKeyHash is in this doc but is harmless to read — it's a hash
      allow read: if true;
      // Only authenticated admins (dashboard) can write
      allow write: if request.auth != null;
    }

    // ── NFC Sessions (Cloud Functions only) ──
    // Sessions are created/updated by Cloud Functions using Admin SDK,
    // which bypasses these rules. Public clients cannot read/write.
    match /nfc_sessions/{sessionId} {
      allow read: if request.auth != null;
      allow write: if false; // Only admin SDK (Cloud Functions)
    }

    // ── Vendors (public onboarding flow) ──
    // Vendors are created/updated during the unauthenticated onboarding process.
    // The onboarding page reads vendor info and writes profile + compliance data.
    match /vendors/{vendorId} {
      // Public can read vendor info (needed for onboarding page load)
      allow read: if true;
      // Public can create new vendor entries (start onboarding page)
      allow create: if true;
      // Public can update vendor profile, compliance, and onboarding fields
      allow update: if true;
    }
  }
}

rules_version='2'

service cloud.firestore {
  match /databases/{database}/documents {

    // ════════════════════════════════════════════════════
    // HELPER FUNCTIONS
    // ════════════════════════════════════════════════════
    function isAuthenticated() {
      return request.auth != null;
    }

    // ════════════════════════════════════════════════════
    // DASHBOARD COLLECTIONS (require authentication)
    // All dashboard users are @xiri.ai — auth is enforced
    // at sign-in. No per-role Firestore rules needed since
    // the dashboard already gates UI by role.
    // ════════════════════════════════════════════════════

    // ── Users (own profile read always; admin can list) ──
    match /users/{userId} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated();
    }

    // ── Companies / Leads (CRM core) ──
    match /companies/{companyId} {
      allow read, write: if isAuthenticated();
    }
    match /leads/{leadId} {
      allow read, write: if isAuthenticated();
    }
    match /contacts/{contactId} {
      allow read, write: if isAuthenticated();
    }

    // ── Sales pipeline ──
    match /quotes/{quoteId} {
      // Public read needed for quote review page (via reviewToken)
      allow read: if true;
      allow write: if isAuthenticated();
    }
    match /contracts/{contractId} {
      allow read, write: if isAuthenticated();
    }

    // ── Operations ──
    match /work_orders/{workOrderId} {
      allow read, write: if isAuthenticated();
    }
    match /invoices/{invoiceId} {
      // Public read needed for invoice payment page (via paymentToken)
      allow read: if true;
      allow write: if isAuthenticated();
    }
    match /commissions/{commissionId} {
      allow read, write: if isAuthenticated();
    }
    match /commission_ledger/{entryId} {
      allow read, write: if isAuthenticated();
    }
    match /vendor_remittances/{remittanceId} {
      allow read, write: if isAuthenticated();
    }

    // ── Activity / Logging ──
    match /lead_activities/{activityId} {
      // Public create for PublicCalculator events
      allow create: if true;
      allow read, update, delete: if isAuthenticated();
    }
    match /activity_logs/{logId} {
      allow read, write: if isAuthenticated();
    }
    match /vendor_activities/{activityId} {
      allow read, write: if isAuthenticated();
    }
    match /scheduled_activities/{activityId} {
      allow read, write: if isAuthenticated();
    }

    // ── Outreach / Sequences / Templates ──
    match /outreach_queue/{outreachId} {
      allow read, write: if isAuthenticated();
    }
    match /sequences/{sequenceId} {
      allow read, write: if isAuthenticated();
    }
    match /templates/{templateId} {
      allow read, write: if isAuthenticated();
    }

    // ── Prospect Queue (auto-prospector) ──
    match /prospect_queue/{prospectId} {
      allow read, write: if isAuthenticated();
    }
    match /prospecting_config/{configId} {
      allow read, write: if isAuthenticated();
    }
    match /facility_types_custom/{typeId} {
      allow read, write: if isAuthenticated();
    }

    // ── Notifications ──
    match /notifications/{notificationId} {
      allow read, write: if isAuthenticated();
    }

    // ── Guides (public read for the public site) ──
    match /guides/{guideId} {
      allow read: if true;
      allow write: if isAuthenticated();
    }

    // ── pSEO Engine (nudges, batches, config) ──
    match /pseo_nudges/{nudgeId} {
      allow read, write: if isAuthenticated();
    }
    match /pseo_batches/{batchId} {
      allow read, write: if isAuthenticated();
    }
    match /pseo_config/{configId} {
      allow read, write: if isAuthenticated();
    }

    // ── Vendor Prospect Queue ──
    match /vendor_prospect_queue/{prospectId} {
      allow read, write: if isAuthenticated();
    }
    match /vendor_prospecting_config/{configId} {
      allow read, write: if isAuthenticated();
    }

    // ════════════════════════════════════════════════════
    // PUBLIC COLLECTIONS (limited access for public site)
    // ════════════════════════════════════════════════════

    // ── Referral leads (public form + payment info page) ──
    match /referral_leads/{referralId} {
      // Anyone can create a new referral (public form)
      allow create: if true;
      // Anyone with the doc ID can read (payment info page)
      allow read: if true;
      // Payment info page can update only payment fields
      allow update: if request.resource.data.diff(resource.data).affectedKeys()
        .hasOnly(['paymentInfo', 'paymentInfoUpdatedAt']);
      // Dashboard users can do anything
      allow update, delete: if isAuthenticated();
    }

    // ── NFC Sites (public read for location info, admin write) ──
    match /nfc_sites/{locationId} {
      allow read: if true;
      allow write: if isAuthenticated();
    }

    // ── NFC Sessions (auth read, Cloud Functions write) ──
    match /nfc_sessions/{sessionId} {
      allow read: if isAuthenticated();
      allow write: if false; // Only admin SDK (Cloud Functions)
    }

    // ── Vendors (public onboarding flow) ──
    match /vendors/{vendorId} {
      allow read: if true;
      allow create: if true;
      allow update: if true;
      // Only dashboard users can delete
      allow delete: if isAuthenticated();
    }

    // ── Lead Magnet Downloads (public create) ──
    match /lead_magnet_downloads/{downloadId} {
      allow create: if true;
      allow read, update, delete: if isAuthenticated();
    }

    // ── Demo Clicks (public create, admin read) ──
    match /demo_clicks/{clickId} {
      allow create: if true;
      allow read: if isAuthenticated();
      allow update, delete: if isAuthenticated();
    }

    // ── AI Bot Visits (public create, admin read) ──
    match /aiBotVisits/{visitId} {
      allow create: if true;
      allow read: if isAuthenticated();
      allow update, delete: if isAuthenticated();
    }
  }
}

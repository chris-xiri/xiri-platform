{
    "name": "@xiri-facility-solutions/shared",
    "version": "0.2.0",
    "description": "Shared business logic, types, and calculator engine for Xiri products",
    "main": "dist/index.js",
    "module": "dist/index.mjs",
    "types": "dist/index.d.ts",
    "exports": {
        ".": {
            "import": "./dist/index.mjs",
            "require": "./dist/index.js",
            "types": "./dist/index.d.ts"
        }
    },
    "files": [
        "dist"
    ],
    "scripts": {
        "build": "tsup",
        "refresh-data": "tsx scripts/generate-market-data.ts",
        "lint": "eslint",
        "prepublishOnly": "npm run build"
    },
    "peerDependencies": {
        "jspdf": "^4.2.0"
    },
    "peerDependenciesMeta": {
        "jspdf": {
            "optional": true
        }
    },
    "dependencies": {
        "pdf-lib": "^1.17.1",
        "zod": "^4.3.6"
    },
    "devDependencies": {
        "jspdf": "^4.2.0",
        "tsup": "^8.0.0",
        "tsx": "^4.0.0",
        "typescript": "^5.0.0"
    },
    "publishConfig": {
        "access": "public"
    },
    "repository": {
        "type": "git",
        "url": "https://github.com/chris-xiri/xiri-platform"
    },
    "license": "MIT"
}

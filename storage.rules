rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    match /social-images/{imageId} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    match /social-videos/{videoId} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    // ACORD 25 uploads from unauthenticated vendor onboarding
    match /acord25/{vendorId}/{fileName} {
      allow read: if true;
      allow write: if true;
    }
    match /{allPaths=**} {
      allow read, write: if request.auth != null;
    }
  }
}
